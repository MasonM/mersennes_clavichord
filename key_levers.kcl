import * from "params.kcl"
import * from "rack_utils.kcl"
import * from "key_utils.kcl"
import * from "string_utils.kcl"

// Key levers are all coplanar: every lever starts at the natural key base Z and
// extrudes to naturalKeyHeight. Accidental levers start at the rear of their
// accidental keys. Natural-key lever bases are narrowed only where adjacent
// accidentals occupy half of the neighboring key edge.
keyLeverZ = keyBaseZ
keyLeverStartY = keywellWidth
keyLeverTaperRun = 24mm
keyLeverAllNarrowY = keyLeverStartY + keyLeverTaperRun + 12mm
keyLeverBendRun = 20mm
keyLeverBendY = keyLeverAllNarrowY + keyLeverBendRun
keyLeverColor = "#8b5a2b"

// Rack tongue dimensions mirror the slots in rack.kcl with clearance. slotYForKey()
// is now the lower/front rack edge, so the tongue end is placed inside the slot,
// short of the rear of the equal-depth cut.
rackTongueSlotWidth = rackSlotWidth
rackTongueSideClearance = 0.35mm
rackTongueWidth = rackTongueSlotWidth - (2 * rackTongueSideClearance)
rackTongueInsetDepth = 10mm
rackTongueEndClearance = 3mm

fn rackTongueEndYForKey(@keyIdx) {
  return slotYForKey(keyIdx) + rackSlotDepth - rackTongueEndClearance
}

fn rackTongueStartYForKey(@keyIdx) {
  return rackTongueEndYForKey(keyIdx) - rackTongueInsetDepth
}

fn makeKeyLever(@keyIdx) {
  bendLeftX = tangentXForKey[keyIdx] - (keyLeverTopWidthForKey(keyIdx) / 2)
  bendRightX = tangentXForKey[keyIdx] + keyLeverTopWidthForKey(keyIdx) / 2

  keyLeverFootprint = sketch(on = XY) {
    startFace = line(start = [var 0mm, var 0mm], end = [var 22mm, var 0mm])
    rightTaperSide = line(start = [var 22mm, var 0mm], end = [var 8mm, var 16mm])
    rightHoldSide = line(start = [var 8mm, var 16mm], end = [var 8mm, var 36mm])
    rightBendSide = line(start = [var 8mm, var 36mm], end = [var 12mm, var 56mm])
    rightStraightSide = line(start = [var 12mm, var 56mm], end = [var 12mm, var 108mm])
    rightTongueShoulder = line(start = [var 12mm, var 108mm], end = [var 2mm, var 116mm])
    rightTongueSide = line(start = [var 2mm, var 116mm], end = [var 2mm, var 160mm])
    endFace = line(start = [var 2mm, var 160mm], end = [var 0mm, var 160mm])
    leftTongueSide = line(start = [var 0mm, var 160mm], end = [var 0mm, var 116mm])
    leftTongueShoulder = line(start = [var 0mm, var 116mm], end = [var 0mm, var 108mm])
    leftStraightSide = line(start = [var 0mm, var 108mm], end = [var 0mm, var 56mm])
    leftBendSide = line(start = [var 0mm, var 56mm], end = [var 0mm, var 36mm])
    leftHoldSide = line(start = [var 0mm, var 36mm], end = [var 0mm, var 16mm])
    leftTaperSide = line(start = [var 0mm, var 16mm], end = [var 0mm, var 0mm])

    coincident([startFace.end, rightTaperSide.start])
    coincident([
      rightTaperSide.end,
      rightHoldSide.start
    ])
    coincident([rightHoldSide.end, rightBendSide.start])
    coincident([
      rightBendSide.end,
      rightStraightSide.start
    ])
    coincident([
      rightStraightSide.end,
      rightTongueShoulder.start
    ])
    coincident([
      rightTongueShoulder.end,
      rightTongueSide.start
    ])
    coincident([rightTongueSide.end, endFace.start])
    coincident([endFace.end, leftTongueSide.start])
    coincident([
      leftTongueSide.end,
      leftTongueShoulder.start
    ])
    coincident([
      leftTongueShoulder.end,
      leftStraightSide.start
    ])
    coincident([
      leftStraightSide.end,
      leftBendSide.start
    ])
    coincident([leftBendSide.end, leftHoldSide.start])
    coincident([leftHoldSide.end, leftTaperSide.start])
    coincident([leftTaperSide.end, startFace.start])

    coincident([
      startFace.start,
      [
        keyLeverStartXForKey(keyIdx) - (keyLeverBottomWidthForKey(keyIdx) / 2),
        keyLeverStartY
      ]
    ])
    coincident([
      startFace.end,
      [
        keyLeverStartXForKey(keyIdx) + keyLeverBottomWidthForKey(keyIdx) / 2,
        keyLeverStartY
      ]
    ])
    coincident([
      rightTaperSide.end,
      [
        keyLeverStartXForKey(keyIdx) + keyLeverBottomWidthForKey(keyIdx) / 2,
        keyLeverStartY + keyLeverTaperRun
      ]
    ])
    coincident([
      rightHoldSide.end,
      [
        keyLeverStartXForKey(keyIdx) + keyLeverBottomWidthForKey(keyIdx) / 2,
        keyLeverAllNarrowY
      ]
    ])
    coincident([
      rightBendSide.end,
      [bendRightX, keyLeverBendY]
    ])
    coincident([
      rightStraightSide.end,
      [
        bendRightX,
        rackTongueStartYForKey(keyIdx)
      ]
    ])
    coincident([
      rightTongueShoulder.end,
      [
        tangentXForKey[keyIdx] + rackTongueWidth / 2,
        rackTongueStartYForKey(keyIdx)
      ]
    ])
    coincident([
      rightTongueSide.end,
      [
        tangentXForKey[keyIdx] + rackTongueWidth / 2,
        rackTongueEndYForKey(keyIdx)
      ]
    ])
    coincident([
      endFace.end,
      [
        tangentXForKey[keyIdx] - (rackTongueWidth / 2),
        rackTongueEndYForKey(keyIdx)
      ]
    ])
    coincident([
      leftTongueSide.end,
      [
        tangentXForKey[keyIdx] - (rackTongueWidth / 2),
        rackTongueStartYForKey(keyIdx)
      ]
    ])
    coincident([
      leftTongueShoulder.end,
      [
        bendLeftX,
        rackTongueStartYForKey(keyIdx)
      ]
    ])
    coincident([
      leftStraightSide.end,
      [bendLeftX, keyLeverBendY]
    ])
    coincident([
      leftBendSide.end,
      [
        keyLeverStartXForKey(keyIdx) - (keyLeverBottomWidthForKey(keyIdx) / 2),
        keyLeverAllNarrowY
      ]
    ])
    coincident([
      leftHoldSide.end,
      [
        keyLeverStartXForKey(keyIdx) - (keyLeverBottomWidthForKey(keyIdx) / 2),
        keyLeverStartY + keyLeverTaperRun
      ]
    ])

    horizontal(startFace)
    horizontal(endFace)
    vertical(rightHoldSide)
    vertical(rightStraightSide)
    vertical(rightTongueSide)
    vertical(leftTongueSide)
    vertical(leftStraightSide)
    vertical(leftHoldSide)
    distance([startFace.start, startFace.end]) == keyLeverBottomWidthForKey(keyIdx)
    distance([endFace.start, endFace.end]) == rackTongueWidth
  }

  hiddenKeyLeverFootprint = hide(keyLeverFootprint)

  return extrude(
    region(
      point = [
        keyLeverStartXForKey(keyIdx),
        keyLeverStartY + keyLeverTaperRun + 1mm
      ],
      sketch = keyLeverFootprint,
    ),
    length = naturalKeyHeight,
    method = NEW,
  )
    |> translate(z = keyLeverZ, global = true)
}

keyLevers = map([0..<numKeys], f = makeKeyLever)
woodKeyLevers = appearance(
  keyLevers,
  color = keyLeverColor,
  roughness = 76,
  metalness = 0,
)
