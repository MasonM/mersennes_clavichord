import cube from "utils.kcl"
import * from "params.kcl"
import * from "rack_utils.kcl"
import * from "temperament.kcl"

slotCutHeight = 50mm
rackHeight = soundboardStart[2] + soundboardHeight
numKeysTest = numKeys
//keys = [0..<numKeys]
//keys[numKeys-1] = 100

export fn soundingLengthForKeyTest2(@keyIdx) {
  return if keyIdx == 0 {
    lowCSoundingLength
  } else if courseIdxForKey(keyIdx) == courseIdxForKey(keyIdx - 1) {
    frequencyForKey(keyIdx - 1) * soundingLengthForKeyTest2(keyIdx - 1) / frequencyForKey(keyIdx)
  } else {
    soundingLengthForKeyTest2(keyIdx - 1) + 5mm
  }
}

export fn soundingLengthForKeyTest(@keyIdx) {
  return if keyIdx >= numKeysTest - 1 {
    soundboardStart[0] - 5mm
  } else if courseIdxForKey(keyIdx) == courseIdxForKey(keyIdx + 1) {
    frequencyForKey(keyIdx + 1) * soundingLengthForKeyTest(keyIdx + 1) / frequencyForKey(keyIdx)
  } else {
    soundingLengthForKeyTest(keyIdx + 1) - 5mm
  }
}
//soundingLengths = map([0..<numKeysTest], f = soundingLengthForKeyTest2)

export fn slotSpacing() {
  return if useEqualTemperament {
    7mm
  } else {
    9mm
  }
}

export fn slotXForKeyTest2(@keyIdx) {
  return if keyIdx == 0 {
    toolboxLength + 10mm
  } else if courseIdxForKey(keyIdx) == courseIdxForKey(keyIdx - 1) {
    bridgeXForString(stringIdxForKey(keyIdx)) - (
      frequencyForKey(keyIdx - 1) * (
        (bridgeXForString(stringIdxForKey(keyIdx - 1)) - slotXForKeyTest2(keyIdx - 1))
        / frequencyForKey(keyIdx)
      )
    )
  } else {
    slotXForKeyTest2(keyIdx - 1) + slotSpacing()
  }
}

slotXForKeysArray = map([0..<numKeysTest], f = slotXForKeyTest2)
export fn slotXForKeyTest(@keyIdx) {
  return if false {
    // TODO: Figure out why this isn't giving the right positions. Did I get the bridge positioning wrong?
    bridgeXForString(stringIdxForKey(keyIdx)) - soundingLengths[keyIdx]
  } else {
    // HACK: return plausible positions instead of calculating based on the
    // sounding length
    slotXForKeysArray[keyIdx]
    //rackBassCutoutX + keyIdx * 13
  }
}

cube([5mm, caseWidth, caseHeight])
  |> translate(x = toolboxLength)

cube([5mm, caseWidth, caseHeight])
  |> translate(x = soundboardStart[0])

fn transformSlot(@keyIdx) {
    return {
        translate =  [
            slotXForKeysArray[keyIdx] - (rackSlotWidth / 2),
            slotYForKey(keyIdx),
            rackHeight - slotCutHeight,
        ]
    }
}

prototypeslot = cube([rackSlotWidth, rackSlotDepth, slotCutHeight])

patternTransform(prototypeslot, instances = numKeysTest, transform = transformSlot)

hiddenPrototypeslot = hide([prototypeslot])

keyIndices = [0..<numKeysTest]
stringIndices = [0..<numStrings]

_courseIndicesForKeys = map(keyIndices, f = courseIdxForKey)
_stringIndicesForKeys = map(keyIndices, f = stringIdxForKey)
_stringForKeys = map(keyIndices, f = stringIdxForKey)
_bridgeXForStrings = map(stringIndices, f = bridgeXForString)
_slotXForKeys = map(keyIndices, f = slotXForKeyTest)
_soundingLengthForKeys = map(keyIndices, f = soundingLengthForKeyTest2)