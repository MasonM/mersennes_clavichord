import cube from "utils.kcl"
import * from "params.kcl"
import * from "rack_utils.kcl"

slotCutHeight = 50mm
rackHeight = soundboardStart[2] + soundboardHeight

cube([5mm, caseWidth, caseHeight])
  |> translate(x = toolboxLength)

cube([5mm, caseWidth, caseHeight])
  |> translate(x = soundboardStart[0])

fn transformSlot(@keyIdx) {
    return {
        translate =  [
            slotXForKey(keyIdx) - (rackSlotWidth / 2),
            slotYForKey(keyIdx),
            rackHeight - slotCutHeight,
        ]
    }
}

prototypeslot = cube([rackSlotWidth, rackSlotDepth, slotCutHeight])

patternTransform(prototypeslot, instances = numKeys, transform = transformSlot)

hiddenPrototypeslot = hide([prototypeslot])

keyIndices = [0..<numKeys]
stringIndices = [0..<numStrings]

_stringIndicesForKeys = map(keyIndices, f = stringIdxForKey)
_stringForKeys = map(keyIndices, f = stringIdxForKey)
_bridgeXForStrings = map(stringIndices, f = bridgeXForString)
_slotXForKeys = map(keyIndices, f = slotXForKey)
_soundingLengthForKeys = map(keyIndices, f = soundingLengthForKey)