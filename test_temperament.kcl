import caseLength, numKeys, numStrings from "params.kcl"
import frequencyForKey, stringIdxForKey, bridgeXForString, slotXForKey from "temperament.kcl"

// Uncomment for debugging
export frequencies = map([0..<numKeys], f = frequencyForKey)
export stringIndicesForKeys = map([0..<numKeys], f = stringIdxForKey)
export stringForKeys = map([0..<numKeys], f = stringIdxForKey)
export bridgeXForStrings = map([0..<numStrings], f = bridgeXForString)
export slotXForKeys = map([0..<numKeys], f = slotXForKey)